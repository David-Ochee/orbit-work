# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orbit_work
REDIS_URL=redis://localhost:6379

# ─── Stellar / Soroban ───────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
# testnet | mainnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# Contract IDs (populated after deployment)
ESCROW_CONTRACT_ID=
REPUTATION_CONTRACT_ID=
# Funded Stellar keypair used by the backend to submit transactions
STELLAR_SECRET_KEY=

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── GitHub OAuth ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# ─── WebAuthn / Passkeys ─────────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=OrbitWork
WEBAUTHN_ORIGIN=http://localhost:3000

# ─── GraphQL ─────────────────────────────────────────────────────────────────
GRAPHQL_PATH=/graphql
# WS endpoint used by graphql-ws
GRAPHQL_WS_PATH=/graphql/ws

# ─── Schema sync (CI) ────────────────────────────────────────────────────────
# Path or URL to the canonical schema.gql; leave blank to use local copy
CANONICAL_SCHEMA=

# ─── KYC ─────────────────────────────────────────────────────────────────────
KYC_PROVIDER_API_KEY=
KYC_PROVIDER_URL=

# ─── Misc ────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
